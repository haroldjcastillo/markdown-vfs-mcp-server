{
  "name": "@hjco/markdown-vfs-mcp-server",
  "version": "0.2.0",
  "description": "High-performance MCP server that exposes large Markdown files as a Virtual File System using a Rust B-Tree index compiled to WebAssembly",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "markdown-vfs-mcp-server": "dist/index.js"
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "markdown",
    "vfs",
    "wasm",
    "llm",
    "agent",
    "rag"
  ],
  "author": "Harold Castillo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/haroldjcastillo/markdown-vfs-mcp-server.git"
  },
  "homepage": "https://github.com/haroldjcastillo/markdown-vfs-mcp-server#readme",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "prepack": "npm run build",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.27.1",
    "@hjco/markdown-btree-core": "^0.1.0"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@types/node": "25.4.0",
    "eslint": "latest",
    "eslint-config-prettier": "latest",
    "prettier": "latest",
    "typescript": "5.9.3",
    "typescript-eslint": "latest"
  }
}
